# One variable for API origin everywhere:
#
# Local (npm run dev):
#   VITE_API_URL=http://localhost:9001
#   The app still calls /api in the browser; Vite proxies /api → this URL (no CORS hassle).
#
# Production (Vercel):
#   VITE_API_URL=https://akademiweal.drghartanto.com

VITE_API_URL=http://localhost:9001

# Guest “try before login”: free global path steps (1…N). Clamped 1–80. Default 5 if unset or invalid.
VITE_GUEST_MAX_FREE_PATH_STEP=5
