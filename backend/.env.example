# Copy to .env and adjust. Loaded automatically by `go run ./cmd` (see godotenv in cmd/main.go).
# Values already set in your shell or Docker are not overridden.

# --- HTTP (listen address) ---
# Preferred: host + port. Empty HTTP_HOST = all interfaces (same as ":PORT").
HTTP_HOST=localhost
HTTP_PORT=9001
# Optional legacy single value (overrides HTTP_HOST + HTTP_PORT when set):
# HTTP_ADDR=:9001

# --- PostgreSQL (matches docker-compose defaults) ---
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=akademiweal
DB_SSLMODE=disable

# Optional pool tuning
# DB_MAX_OPEN_CONNS=25
# DB_MAX_IDLE_CONNS=5
# DB_CONN_MAX_LIFETIME=5m
# DB_CONN_MAX_IDLE_TIME=1m

# --- JWT (set a long random string in production) ---
JWT_SECRET=change-me-in-production
