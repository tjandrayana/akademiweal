# Copy to .env and adjust. Loaded via godotenv in cmd/main.go (./.env then backend/.env overlay).

# --- HTTP (listen address) ---
HTTP_HOST=localhost
HTTP_PORT=9001
# HTTP_ADDR=:9001

# --- PostgreSQL (discrete variables — recommended) ---
# Values are combined into a postgresql:// URI in code; special characters in DB_PASSWORD are safe.
# Remote Supabase: use DB_SSLMODE=require (disable is for local Docker only).
DB_HOST=db.xxxxx.supabase.co
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your-password
DB_NAME=akademiweal
DB_SSLMODE=require
# If IPv6 to Supabase is unroutable from your network, force IPv4 DNS/dial + hostaddr:
# for local development set it true, for production set it false
# DB_PREFER_IPV4=true
# DB_HOSTADDR=

# Optional: only used when DB_HOST is omitted (e.g. some CI). If DB_HOST is set, this is ignored.
# DATABASE_URL=postgresql://postgres:pass@db.xxxxx.supabase.co:5432/postgres

# Optional pool tuning
# DB_MAX_OPEN_CONNS=25
# DB_MAX_IDLE_CONNS=5
# DB_CONN_MAX_LIFETIME=5m
# DB_CONN_MAX_IDLE_TIME=1m
#
# PgBouncer / pooler: default is simple protocol (no server prepared stmt cache). If you connect
# direct to Postgres and want pgx statement cache back: DB_PGX_USE_PREPARED_STATEMENTS=1

# --- JWT ---
JWT_SECRET=change-me-in-production
