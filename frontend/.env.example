# Copy to .env.local or .env (Vite loads both; see https://vite.dev/guide/env-and-mode.html)
#
# Backend host + port (used by the dev server proxy: /api → http://HOST:PORT).
# In production builds, if you set either variable, the client uses http://HOST:PORT as the API base
# unless VITE_API_URL is set. Leave both unset in prod to keep same-origin /api (e.g. reverse proxy).

VITE_API_HOST=localhost
VITE_API_PORT=9001

# Optional full URL override (wins over host/port; use for https:// or non-default paths):
# VITE_API_URL=https://api.example.com
