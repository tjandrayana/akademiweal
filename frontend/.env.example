# Copy to .env.local or .env (Vite loads both; see https://vite.dev/guide/env-and-mode.html)
#
# Dev proxy: /api → backend. Use ONE of:
#   A) VITE_API_HOST + VITE_API_PORT (default local: localhost:9001)
#   B) VITE_API_PROXY_TARGET — full URL (e.g. https://api.example.com or http://1.2.3.4:9001)
#
# Vite bakes VITE_* into the JS at **build** time. On Vercel, set these for Preview + Production
# and redeploy after changes. HTTP_HOST/HTTP_PORT are backend-only — they do not affect the SPA.
#
# Priority in production (src/api/client.js): VITE_API_URL → VITE_API_PROXY_TARGET → VITE_API_HOST+PORT

VITE_API_HOST=localhost
VITE_API_PORT=9001
# VITE_API_PROXY_TARGET=http://127.0.0.1:9001

# Clearest for production (include scheme and port if not 80/443):
# VITE_API_URL=http://your-server:9001
