# Copy to .env.local or .env (Vite loads both; see https://vite.dev/guide/env-and-mode.html)
#
# Dev proxy: /api → backend. Use ONE of:
#   A) VITE_API_HOST + VITE_API_PORT (default local: localhost:9001)
#   B) VITE_API_PROXY_TARGET — full URL when the API is on a domain (https://api.example.com); ignores host/port.
#
# Production build: VITE_API_URL or host/port — see client src/api/client.js

VITE_API_HOST=localhost
VITE_API_PORT=9001
# VITE_API_PROXY_TARGET=https://api.example.com

# Optional full URL for production / direct API base (wins over host/port in prod build):
# VITE_API_URL=https://api.example.com
